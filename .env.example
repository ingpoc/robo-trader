# ============================================================================
# ENVIRONMENT VARIABLES TEMPLATE FOR ROBO TRADER
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - this file is safe to commit
#
# This is the SINGLE SOURCE OF TRUTH for all credentials.
# The backend uses python-dotenv to load .env automatically.
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your actual credentials

# ============================================================================
# CLAUDE AGENT SDK AUTHENTICATION
# ============================================================================
# DO NOT set ANTHROPIC_API_KEY here
# Claude Agent SDK uses Claude Code CLI authentication only
#
# To authenticate:
#   claude auth login
#
# The SDK will automatically use your Claude Code CLI credentials
# Model selection comes from ~/.claude/settings.json
# Example:
#   { "model": "haiku" }

# ============================================================================
# ZERODHA KITE CONNECT API CREDENTIALS
# ============================================================================
# Get these from https://kite.zerodha.com/connect/api
# Create an app and use the API Key and Secret provided
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret

# OAuth tokens are auto-generated by the app when you authenticate
# DO NOT set these manually - they will be added automatically after OAuth
# ZERODHA_ACCESS_TOKEN=
# ZERODHA_USER_ID=
# ZERODHA_TOKEN_EXPIRES_AT=
#
# Account context is required for session restore and env-token binding.
# The Zerodha user id is also the account id for this runtime.
# Set one of these for the account this runtime should use:
# PAPER_TRADING_ACCOUNT_ID=
# ZERODHA_ACCOUNT_ID=
# ZERODHA_USER_ID=

# REDIRECT_URL is automatically selected based on environment:
# - Development: http://localhost:8010/api/auth/zerodha/callback
# - Docker: http://robo-trader-app:8000/api/auth/zerodha/callback
# - Production: https://your-domain.com/api/auth/zerodha/callback

# ============================================================================
# UPSTOX QUOTE STREAM (DEFAULT PAPER-MODE LIVE MARKS)
# ============================================================================
# Market Data Feed V3 powers live paper-trading marks without requiring Zerodha Connect.
# Generate an access token through your Upstox app OAuth flow, then set:
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8010/api/auth/upstox/callback
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# Quote stream defaults
QUOTE_STREAM_PROVIDER=upstox
UPSTOX_STREAM_MODE=ltpc

# Upstox Sandbox (order APIs only — market data always uses live feed)
# Create sandbox app at: https://account.upstox.com/developer/apps#sandbox
# Sandbox token has 30-day validity; does NOT expire daily like live token
UPSTOX_SANDBOX=false
UPSTOX_SANDBOX_ACCESS_TOKEN=your_upstox_sandbox_access_token

# ============================================================================
# LEGACY PERPLEXITY API KEYS
# ============================================================================
# Deprecated: the primary paper-trading research path now uses Claude Agent SDK web research.
# Keep only if you still run older legacy modules that have not yet been migrated.
PERPLEXITY_API_KEYS=

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_NAME=robo_trader

# ============================================================================
# RABBITMQ CONFIGURATION (Optional - for message queue)
# ============================================================================
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
# Environment: development, docker, or production
ENVIRONMENT=development
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
