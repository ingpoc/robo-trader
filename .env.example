# ============================================================================
# ENVIRONMENT VARIABLES TEMPLATE FOR ROBO TRADER
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - this file is safe to commit
#
# This is the SINGLE SOURCE OF TRUTH for all credentials.
# The backend uses python-dotenv to load .env automatically.
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your actual credentials

# ============================================================================
# CLAUDE AGENT SDK AUTHENTICATION
# ============================================================================
# DO NOT set ANTHROPIC_API_KEY here
# Claude Agent SDK uses Claude Code CLI authentication only
#
# To authenticate:
#   claude auth
#
# The SDK will automatically use your Claude Code CLI credentials

# ============================================================================
# ZERODHA KITE CONNECT API CREDENTIALS
# ============================================================================
# Get these from https://kite.zerodha.com/connect/api
# Create an app and use the API Key and Secret provided
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret

# OAuth tokens are auto-generated by the app when you authenticate
# DO NOT set these manually - they will be added automatically after OAuth
# ZERODHA_ACCESS_TOKEN=
# ZERODHA_USER_ID=
# ZERODHA_TOKEN_EXPIRES_AT=

# REDIRECT_URL is automatically selected based on environment:
# - Development: http://localhost:8000/api/auth/zerodha/callback
# - Docker: http://robo-trader-app:8000/api/auth/zerodha/callback
# - Production: https://your-domain.com/api/auth/zerodha/callback

# ============================================================================
# PERPLEXITY API KEYS
# ============================================================================
# Get from https://www.perplexity.ai/settings/api
# Multiple keys can be comma-separated for load balancing
PERPLEXITY_API_KEYS=pplx-your_first_api_key,pplx-your_second_api_key

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_NAME=robo_trader

# ============================================================================
# RABBITMQ CONFIGURATION (Optional - for message queue)
# ============================================================================
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
# Environment: development, docker, or production
ENVIRONMENT=development
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
